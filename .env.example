# PostgreSQL from docker-compose.yml (host port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/auragaze?schema=public"

# Generate for each environment: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Used only by `npx prisma db seed`
ADMIN_EMAIL="admin@auragaze.local"
ADMIN_PASSWORD="replace-with-a-strong-password"
